# ShipmentDoc Compliance AI — Environment Variables Template
# Copy this file to .env and fill in your own values
# NEVER commit .env to GitHub

# OpenAI API Key (required for both portals)
OPENAI_API_KEY=your_openai_api_key_here

# n8n Webhook URL (required for Freight Forwarder Portal)
N8N_WEBHOOK_URL=your_n8n_webhook_url_here

# Optional: LangSmith (for evaluation and tracing)
LANGCHAIN_API_KEY=your_langsmith_api_key_here
LANGCHAIN_TRACING_V2=true
LANGCHAIN_PROJECT=shipdoc-compliance-ai
